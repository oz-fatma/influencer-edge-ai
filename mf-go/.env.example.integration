# InfluencerEdge integration — runs alongside backend/ without port conflicts
# Copy to .env before ./dev.sh

SERVER_PORT=8081

DB_HOST=localhost
DB_PORT=5434
DB_USER=masterfabric
DB_PASSWORD=masterfabric
DB_NAME=masterfabric
DB_SSLMODE=disable

REDIS_HOST=localhost
REDIS_PORT=6380

# Use in-process events locally (no Kafka required)
KAFKA_ENABLED=false

JWT_SECRET=local-dev-influencer-edge-mf-go
JWT_EXPIRATION_HOURS=24

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://influencer-edge-ai.vercel.app

# On shared Render Postgres (influencer_edge_db), use schema "mf" so legacy public.users stays untouched:
# DB_SCHEMA=mf
LOG_LEVEL=info
LOG_FORMAT=text

# Optional: proxy Analyze to local Ollama via Cloudflare tunnel
# LLM_BASE_URL=https://your-tunnel.trycloudflare.com
# LLM_MODEL=gemma2:2b
# LLM_TIMEOUT_SECONDS=300
# SERVER_WRITE_TIMEOUT_SECONDS=600
